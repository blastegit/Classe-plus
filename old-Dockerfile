# Utiliser une image Python officielle légère
FROM python:3.11-slim

# Définition du répertoire de travail
WORKDIR /app

# Copie des fichiers nécessitant d'être installés en premier (pour le cache Docker)
COPY requirements.txt .

# Installation des dépendances sans conserver le cache pip
RUN pip install --no-cache-dir -r requirements.txt

# Copie du reste des fichiers de l'application
COPY . .

# Exposer le port par défaut de l'application
EXPOSE 5000

# Lancement en production via Gunicorn (plus robuste que flask run)
CMD ["gunicorn", "-w", "4", "-b", "0.0.0.0:5000", "app:app"]
